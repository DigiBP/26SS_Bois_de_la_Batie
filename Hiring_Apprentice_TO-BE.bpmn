    <bpmn:scriptTask id="Activity_09l2bb3" name="extract salary variables" scriptFormat="javascript">
      <bpmn:incoming>Flow_0aa11m2</bpmn:incoming>
      <bpmn:outgoing>Flow_17p74ba</bpmn:outgoing>
      <bpmn:script>var result = execution.getVariable("contractDecision");

execution.setVariable("salaryY1", result.get("salaryY1"));
execution.setVariable("salaryY2", result.get("salaryY2"));
execution.setVariable("salaryY3", result.get("salaryY3"));
execution.setVariable("weeksOfHolidaysY1", result.get("weeksOfHolidaysY1"));
execution.setVariable("weeksOfHolidaysY2", result.get("weeksOfHolidaysY2"));
execution.setVariable("weeksOfHolidaysY3", result.get("weeksOfHolidaysY3"));</bpmn:script>
    </bpmn:scriptTask>
